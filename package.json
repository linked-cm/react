{
  "name": "@_linked/react",
  "version": "1.4.2",
  "license": "MIT",
  "linkedPackage": true,
  "type": "module",
  "description": "React bindings for @_linked/core",
  "sideEffects": [
    "./lib/esm/package.js"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Semantu/linked-react.git"
  },
  "main": "lib/esm/index.js",
  "module": "lib/esm/index.js",
  "types": "./lib/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/esm/index.d.ts",
      "import": "./lib/esm/index.js"
    },
    "./*": {
      "types": "./lib/esm/*.d.ts",
      "import": "./lib/esm/*.js"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "lib/esm/*"
      ]
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "lib",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npx rimraf ./lib && npx tsc -p tsconfig-esm.json",
    "compile": "echo '💫 Compiling ESM' && npx tsc -p tsconfig-esm.json",
    "test": "NODE_OPTIONS=--experimental-vm-modules npx jest --config jest.config.cjs"
  },
  "peerDependencies": {
    "@_linked/core": "^2.10",
    "react": "^18.2.0"
  },
  "dependencies": {
    "react-usestateref": "^1.0.8"
  },
  "devDependencies": {
    "@_linked/core": "^2.10",
    "@_linked/rdf-mem-store": "^1.0.0",
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@jest/globals": "^29.7.0",
    "@testing-library/react": "^14.2.1",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.7",
    "@types/react": "^18.2.61",
    "@types/react-dom": "^18.2.19",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rimraf": "^5.0.7",
    "ts-jest": "^29.1.2",
    "typescript": "^5.7.3"
  }
}
