{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "@_linked/react": ["./src/index"],
      "@_linked/react/*": ["./src/*"],
      "@_linked/core/test-helpers/*": ["../core/src/test-helpers/*"]
    }
  },
  "include": [
    "./src/**/*.ts",
    "./src/**/*.tsx"
  ]
}
